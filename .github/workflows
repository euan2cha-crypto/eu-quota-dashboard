name: Update EU Quota

on:
  schedule:
    - cron: '0 22 * * *'
  workflow_dispatch:

permi*sions:
  contents: write

jobs:
 *update:
    runs-on: ubuntu-latest*
    steps:

      - uses: actions*checkout@v4

      - uses: actions*setup-python@v5
        with:
    *     python-version: "3.12"

     *- run: |
          pip install req*ests beautifulsoup4

      - run: *
          python scripts/update_q*ota.py

      - run: |
          g*t config user.name "github-actions*
          git config user.email "*ction@github.com"

          git a*d data/quota.json

          git d*ff --cached --quiet || (
         *  git commit -m "auto update quota*
            git push
          )
*
